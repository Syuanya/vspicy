# VSpicy backend local environment example
# Copy to .env and adjust locally. Do not commit .env.

SPRING_PROFILES_ACTIVE=local

# MySQL
VSPICY_DB_HOST=127.0.0.1
VSPICY_DB_PORT=3306
VSPICY_DB_NAME=vspicy
VSPICY_DB_USERNAME=vspicy
VSPICY_DB_PASSWORD=change_me

# Redis
VSPICY_REDIS_HOST=127.0.0.1
VSPICY_REDIS_PORT=6379
VSPICY_REDIS_PASSWORD=change_me

# MinIO
VSPICY_MINIO_ENDPOINT=http://127.0.0.1:9000
VSPICY_MINIO_BUCKET=vspicy
VSPICY_MINIO_ACCESS_KEY=change_me
VSPICY_MINIO_SECRET_KEY=change_me

# RocketMQ
VSPICY_ROCKETMQ_NAME_SERVER=127.0.0.1:9876

# Nacos
VSPICY_NACOS_SERVER_ADDR=127.0.0.1:8848

# Video local storage
VSPICY_VIDEO_TEMP_ROOT=D:/workspace/vspicy/runtime/video/temp
VSPICY_VIDEO_MERGED_ROOT=D:/workspace/vspicy/runtime/video/merged
VSPICY_VIDEO_HLS_ROOT=D:/workspace/vspicy/runtime/video/hls
VSPICY_FFMPEG_PATH=ffmpeg

# Local diagnostics
VSPICY_DEV_CONFIG_DIAGNOSTICS_ENABLED=true
